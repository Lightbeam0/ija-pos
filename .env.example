# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ijapos"

# JWT secret — generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit the real .env file to version control.
JWT_SECRET="replace-with-a-long-random-secret"

# JWT expiry
JWT_EXPIRES_IN="8h"

# Server port
PORT=3001

# Environment
NODE_ENV="development"

# Tax rate (0.12 = 12% Philippine VAT)
TAX_RATE=0.12

# CORS — frontend origin allowed to call the API
FRONTEND_URL="http://localhost:5173"

# Shop details (used in receipts)
SHOP_NAME="MotoParts"
SHOP_ADDRESS="Zamboanga City"
SHOP_PHONE=""
