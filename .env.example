# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/motoparts"

# JWT secret — change this to a long random string in production
JWT_SECRET="change-this-to-a-long-random-secret-string"

# JWT expiry
JWT_EXPIRES_IN="8h"

# Server port
PORT=3001

# Environment
NODE_ENV="development"

# Tax rate (0.12 = 12% Philippine VAT)
TAX_RATE=0.12

# Shop details (used in receipts)
SHOP_NAME="MotoParts"
SHOP_ADDRESS="Zamboanga City"
SHOP_PHONE=""
